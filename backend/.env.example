# Backend environment variables — copy to .env locally, set these in Render's Variables tab for prod.

# ============================================================
# LLM providers (router picks whichever has a key, in order)
# ============================================================
# Sign-up for each free tier (all OpenAI-compatible):
#   Groq:       https://console.groq.com (Llama 3.3 70B, ~720x Gemini free tier)
#   Cerebras:   https://cloud.cerebras.ai (Llama 3.3 70B, fastest inference)
#   OpenRouter: https://openrouter.ai/keys (free :free models + paid fallback)
#   Gemini:     https://aistudio.google.com (last-resort fallback)

# --- Provider 1: Groq (primary) ---
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Provider 2: Cerebras (fallback #1) ---
CEREBRAS_API_KEY=your_cerebras_key_here
CEREBRAS_MODEL=llama-3.3-70b

# --- Provider 3: OpenRouter (fallback #2) ---
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Provider 4: Gemini (last-resort fallback) ---
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# ============================================================
# LLM cache (SQLite + semantic match)
# ============================================================
# Caches repeated questions ("Explain Two Sum", "Give me a hint", etc.)
# Exact + semantic matching, no external service needed.
LLM_CACHE_ENABLED=true
LLM_CACHE_DB_PATH=./data/llm_cache.db
# Cosine similarity threshold for a semantic match. Higher = stricter.
LLM_CACHE_THRESHOLD=0.92
# Skip semantic matching for very short queries (too generic).
LLM_CACHE_MIN_QUERY_LEN=8
# Embedder model (downloaded once on first run, cached in ~/.cache/fastembed).
LLM_CACHE_EMBED_MODEL=BAAI/bge-small-en-v1.5

# ============================================================
# Code execution (Judge0)
# ============================================================
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# ============================================================
# Server
# ============================================================
CORS_ORIGINS=https://mock-with-ai.is-a.dev,https://mock-with-ai.vercel.app,http://localhost:5173
PORT=8000
ENV=production
