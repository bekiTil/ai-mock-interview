# Backend environment variables — copy to .env locally, set these in Railway's Variables tab for prod.

# --- LLM ---
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Code execution (Judge0) ---
# Option A: Judge0 CE on RapidAPI (easiest)
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Option B: self-hosted Judge0 (leave JUDGE0_API_KEY empty if no auth)
# JUDGE0_API_URL=https://your-judge0-instance.example.com
# JUDGE0_API_KEY=
# JUDGE0_API_HOST=

# --- CORS ---
# Comma-separated list of allowed origins. MUST include your Vercel prod URL + is-a.dev subdomain.
# During local dev add http://localhost:5173 too.
CORS_ORIGINS=https://mock-with-ai.is-a.dev,https://mock-with-ai.vercel.app,http://localhost:5173

# --- Server ---
# Railway provides PORT automatically; this is only used for local docker run.
PORT=8000

# Optional: set to "production" so you can gate debug logs.
ENV=production